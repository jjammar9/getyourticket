generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id              String         @id @default(cuid())
  name            String
  email           String         @unique
  password        String
  avatar          String?
  role            String         @default("customer")
  resetToken      String?
  resetTokenExpiry DateTime?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  wishlistLists   WishlistList[]
  bookings        Booking[]
  reviews         Review[]
}

model WishlistList {
  id        String         @id @default(cuid())
  name      String
  userId    String
  user      User           @relation(fields: [userId], references: [id])
  items     WishlistItem[]
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
}

model WishlistItem {
  id             String       @id @default(cuid())
  wishlistListId String
  listingId      String
  wishlistList   WishlistList @relation(fields: [wishlistListId], references: [id])
  listing        Listing      @relation(fields: [listingId], references: [id])
  createdAt      DateTime     @default(now())

  @@unique([wishlistListId, listingId])
}

model Booking {
  id          String   @id @default(cuid())
  userId      String
  listingId   String
  date        String
  guests      Int
  totalPrice  Float
  status      String   @default("confirmed")
  user        User     @relation(fields: [userId], references: [id])
  listing     Listing  @relation(fields: [listingId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Review {
  id        String   @id @default(cuid())
  listingId String
  userId    String?
  name      String
  date      String
  rating    Int
  text      String
  image     String?
  listing   Listing  @relation(fields: [listingId], references: [id])
  user      User?    @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())
}

model SiteContent {
  id    String @id @default(cuid())
  key   String @unique
  value Json
}

model NewsletterSubscriber {
  id           String   @id @default(cuid())
  email        String   @unique
  subscribedAt DateTime @default(now())
}

model Country {
  id          String    @id @default(cuid())
  slug        String    @unique
  name        String
  description String?
  image       String?
  continent   String?
  cities      Json?
  attractions Json?
  guides      Json?
  listings    Listing[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Category {
  id        String    @id @default(cuid())
  slug      String    @unique
  name      String
  icon      String?
  listings  Listing[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Listing {
  id                 String   @id @default(cuid())
  slug               String   @unique
  expId              Int      @unique
  title              String
  description        String?
  badge              String?
  images             String[]
  gallery            String[]
  price              Float
  oldPrice           Float?
  duration           String?
  location           String?
  extras             String?
  rating             Float?
  reviewsCount       Int?
  highlights         String[]
  included           String[]
  meetingPoint       String?
  cancellationPolicy String?
  countryId          String
  categoryId         String
  country            Country  @relation(fields: [countryId], references: [id])
  category           Category @relation(fields: [categoryId], references: [id])
  reviews            Review[]
  wishlistItems      WishlistItem[]
  bookings           Booking[]
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}